# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=false

# --- Database (SQLite by default - no setup needed) ---
DATABASE_URL=

# ============================================================
# LLM PROVIDER CHAIN: Google Gemini → Anthropic → Together AI → Ollama
# ============================================================

# --- PRIMARY: Google Gemini Flash (Free Tier) ---
# Get your free API key at: https://aistudio.google.com/app/apikey
# Free tier: ~1,500 requests/day, no credit card required for signup
# gemini-2.5-flash is fast, capable, and the most generous free-tier option
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL_ID=gemini-2.5-flash

# --- FALLBACK 1: Anthropic Claude Haiku (Free Tier) ---
# Get your free API key at: https://console.anthropic.com/
# Free tier: generous rate limits (20+ req/min), no credit card required for signup
# claude-haiku-4-5-20251001 is fast, capable, and free-tier friendly
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL_ID=claude-haiku-4-5-20251001

# --- FALLBACK 2: Together AI (Free Tier) ---
# Get your free API key at: https://api.together.xyz/
# Free tier: ~60 req/min, no credit card required
# Great open-source models available for free
TOGETHER_API_KEY=your_together_api_key_here
TOGETHER_MODEL_ID=meta-llama/Llama-3-8b-chat-hf

# --- FALLBACK 3: Ollama (Local only) ---
# Only works if Ollama is installed & running on this same machine.
# Install: https://ollama.com  |  Then run: ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_ID=llama3.1

# --- Code review temp file storage ---
RUNS_DIR=./runs
